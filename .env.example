# Environment Variables for Hosting Platforms
# Copy this file to .env and fill in your values

# ===== MILESTONE 1 CONFIGURATION =====
# Application Settings
APP_NAME=Customer Churn Predictor
DEBUG=False
HOST=0.0.0.0
PORT=8501

# File Paths (use relative paths for hosting compatibility)
DATA_PATH=./data/churn.csv
MODELS_PATH=./ml/models/
OUTPUTS_PATH=./outputs/

# ===== MILESTONE 2 CONFIGURATION (for later) =====
# LLM API Keys (when implementing Milestone 2)
# OPENAI_API_KEY=your_openai_api_key_here
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your_langchain_api_key_here

# Vector Store Settings
# CHROMA_PERSIST_PATH=./rag/chroma_db
# FAISS_INDEX_PATH=./rag/faiss_index

# ===== HOSTING PLATFORM SPECIFIC =====
# Streamlit Cloud - no additional config needed
# Hugging Face Spaces - create app.py in root
# Render - ensure PORT environment variable is used